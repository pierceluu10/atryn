# Set MOCK_AI=true to stub Bedrock calls locally
MOCK_AI=true

# Set USE_DYNAMO=true to read from DynamoDB instead of seed JSON
USE_DYNAMO=false

# AWS Region
AWS_REGION=us-east-1

# DynamoDB table name
DYNAMO_TABLE=CampusResources

# Bedrock model ID
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
