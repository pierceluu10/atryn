# Set MOCK_AI=true to stub Gemini calls locally
MOCK_AI=true

# Set USE_DYNAMO=true to read from DynamoDB instead of seed JSON
USE_DYNAMO=false

# AWS Region
AWS_REGION=us-east-1

# DynamoDB table name
DYNAMO_TABLE=CampusResources

# Google Gemini API key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Gemini model name
GEMINI_MODEL=gemini-2.0-flash
